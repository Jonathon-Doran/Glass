<Window x:Class="Inference.Dialogs.PacketDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Packet Detail"
        Height="600" Width="1000"
        ShowInTaskbar="False">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="8,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Packet:" FontWeight="SemiBold" Margin="0,0,4,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="HeaderPacketIndex" Margin="0,0,16,2"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Timestamp:" FontWeight="SemiBold" Margin="0,0,4,2"/>
                <TextBlock Grid.Row="0" Grid.Column="3" x:Name="HeaderTimestamp" Margin="0,0,16,2"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Length:" FontWeight="SemiBold" Margin="0,0,4,2"/>
                <TextBlock Grid.Row="0" Grid.Column="5" x:Name="HeaderLength" Margin="0,0,16,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Opcode:" FontWeight="SemiBold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HeaderOpcode" Margin="0,0,16,0"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Channel:" FontWeight="SemiBold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" x:Name="HeaderChannel" Margin="0,0,16,0"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="Character:" FontWeight="SemiBold" Margin="0,0,4,0"/>
                <TextBlock Grid.Row="1" Grid.Column="5" x:Name="HeaderCharacter" Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Fields" FontWeight="SemiBold" Margin="8,4,8,2"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="8,0,4,8">
                    <TextBox x:Name="FieldTextBox"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             BorderThickness="0"
                             Background="Transparent"/>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Hex" FontWeight="SemiBold" Margin="8,4,8,2"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="4,0,8,8">
                    <TextBox x:Name="HexDumpTextBox"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="13"
                             TextWrapping="NoWrap"
                             BorderThickness="0"
                             Background="Transparent"/>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>