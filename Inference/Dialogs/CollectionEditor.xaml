<Window x:Class="Inference.Dialogs.CollectionEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:uiconv="clr-namespace:Inference.UI"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Collection Editor"
        Width="1100"
        Height="900"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <uiconv:StringToVisibilityConverter x:Key="StringToVisibility" />
        <uiconv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="NoDetailChromeRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="DetailsVisibility"
                Value="{Binding any_detail, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========================================================================== -->
        <!-- Top:  Patch level + collection selectors                                    -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <TextBlock Text="Patch:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="PatchLevelComboBox"
                      Width="240"
                      Margin="0,0,16,0"
                      SelectionChanged="PatchLevelComboBox_SelectionChanged" />

            <TextBlock Text="Collection:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="CollectionComboBox"
                      Width="280"
                      Margin="0,0,16,0"
                      SelectionChanged="CollectionComboBox_SelectionChanged" />

            <TextBlock Text="Name:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <TextBox x:Name="CollectionNameTextBox"
                     Width="240"
                     Margin="0,0,16,0" />

            <Button x:Name="ClearButton"
                    Content="Clear"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="ClearButton_Click" />
        </StackPanel>

        <!-- =========================================================================== -->
        <!-- Row 1:  PacketField grid                                                    -->
        <!-- =========================================================================== -->
        <GroupBox Grid.Row="1"
                  Header="Fields"
                  Margin="0,0,0,8">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Button x:Name="AddFieldButton"
                            Content="Add"
                            Width="60"
                            Margin="0,0,4,0"
                            Click="AddFieldButton_Click" />
                    <Button x:Name="DeleteFieldButton"
                            Content="Delete"
                            Width="60"
                            Margin="0,0,16,0"
                            Click="DeleteFieldButton_Click" />

                    <Button x:Name="ToggleRelativeToButton"
                            Content="Relative To"
                            Width="90"
                            Margin="0,0,4,0"
                            Click="ToggleRelativeToButton_Click" />
                    <Button x:Name="ToggleGateButton"
                            Content="Gate"
                            Width="60"
                            Margin="0,0,4,0"
                            Click="ToggleGateButton_Click" />
                    <Button x:Name="TogglePredicateButton"
                            Content="Predicate"
                            Width="80"
                            Click="TogglePredicateButton_Click" />
                </StackPanel>

                <DataGrid x:Name="FieldsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="All"
                          SelectionMode="Single"
                          RowStyle="{StaticResource NoDetailChromeRowStyle}"
                          VerticalAlignment="Top">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"
                            Binding="{Binding sequence}"
                            Width="80" />
                        <DataGridTextColumn Header="Name"
                            Binding="{Binding field_name}"
                            Width="*" />
                        <DataGridTextColumn Header="Bit Offset"
                            Binding="{Binding bit_offset}"
                            Width="80" />
                        <DataGridTextColumn Header="Bit Length"
                            Binding="{Binding bit_length}"
                            Width="80" />
                        <DataGridComboBoxColumn x:Name="FieldEncodingColumn"
                            Header="Encoding"
                            SelectedValueBinding="{Binding encoding}"
                            Width="160" />
                        <DataGridTextColumn Header="Divisor"
                            Binding="{Binding divisor}"
                            Width="70" />
                    </DataGrid.Columns>

                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="24,2,8,6">

                                <!-- Relative To -->
                                <Grid Margin="0,0,16,0">
                                    <Grid.Visibility>
                                        <MultiBinding Converter="{StaticResource StringToVisibility}" Mode="OneWay">
                                            <Binding Path="relative_to" />
                                            <Binding Path="show_relative_to" />
                                        </MultiBinding>
                                    </Grid.Visibility>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                        Text="Relative To:"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                        MinWidth="120"
                                        HorizontalAlignment="Left"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Text="{Binding relative_to, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- Gate -->
                                <Grid Margin="0,0,16,0">
                                    <Grid.Visibility>
                                        <MultiBinding Converter="{StaticResource StringToVisibility}" Mode="OneWay">
                                            <Binding Path="gate" />
                                            <Binding Path="show_gate" />
                                        </MultiBinding>
                                    </Grid.Visibility>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                        Text="Gate:"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                        MinWidth="120"
                                        HorizontalAlignment="Center"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Text="{Binding gate, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!-- Predicate -->
                                <Grid Margin="0,0,16,0">
                                    <Grid.Visibility>
                                        <MultiBinding Converter="{StaticResource StringToVisibility}" Mode="OneWay">
                                            <Binding Path="predicate" />
                                            <Binding Path="show_predicate" />
                                        </MultiBinding>
                                    </Grid.Visibility>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                        Text="Predicate:"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0" />
                                    <TextBox Grid.Column="1"
                                        MinWidth="120"
                                        HorizontalAlignment="Center"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Text="{Binding predicate, UpdateSourceTrigger=PropertyChanged}" />

                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <!-- =========================================================================== -->
        <!-- Bottom:  Save / Close                                                       -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="CloseButton"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>