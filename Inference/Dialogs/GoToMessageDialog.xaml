<Window x:Class="Inference.Dialogs.GoToMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Go To Message" Height="240" Width="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <StackPanel Background="{DynamicResource ApplicationPageBackgroundThemeBrush}" Margin="16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="You are here:" Margin="0,0,8,0"/>
            <TextBlock x:Name="CurrentMessageText" Text=""/>
        </StackPanel>
        <TextBlock Text="You want to go to:" Margin="0,0,0,4"/>
        <TextBox x:Name="TargetMessageBox" Margin="0,0,0,12"
                 KeyDown="TargetMessageBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="You can't go further than:" Margin="0,0,8,0"/>
            <TextBlock x:Name="MaxMessageText" Text=""/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Go" Click="Button_Go_Click" MinWidth="80" Margin="0,0,8,0"/>
            <Button Content="Cancel" Click="Button_Cancel_Click" MinWidth="80"/>
        </StackPanel>
    </StackPanel>
</Window>