<Window x:Class="Inference.Dialogs.GateEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Gate Editor"
        Width="717"
        Height="357"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========================================================================== -->
        <!-- Top:  Patch level + gate selectors                                          -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <TextBlock Text="Patch:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="PatchLevelComboBox"
                      Width="240"
                      Margin="0,0,16,0"
                      SelectionChanged="PatchLevelComboBox_SelectionChanged" />

            <TextBlock Text="Gate:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <ComboBox x:Name="GateComboBox"
                      Width="280"
                      Margin="0,0,16,0"
                      SelectionChanged="GateComboBox_SelectionChanged" />

            <Button x:Name="ClearButton"
                    Content="Clear"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="ClearButton_Click" />

            <Button x:Name="DeleteButton"
                    Content="Delete"
                    Width="80"
                    Click="DeleteButton_Click" />
        </StackPanel>

        <!-- =========================================================================== -->
        <!-- Row 1:  Gate form                                                           -->
        <!-- =========================================================================== -->
        <GroupBox Grid.Row="1"
                  Header="Gate"
                  Margin="0,0,0,8"
                  VerticalAlignment="Top">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Name:"
                           VerticalAlignment="Center"
                           Margin="0,4,8,4" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="GateNameTextBox"
                         Margin="0,4,0,4" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Kind:"
                           VerticalAlignment="Center"
                           Margin="0,4,8,4" />
                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,4,0,4">
                    <ComboBox x:Name="KindComboBox"
                              Width="160"
                              SelectionChanged="KindComboBox_SelectionChanged" />

                    <TextBlock x:Name="CountFieldLabel"
                               Text="Count Field:"
                               VerticalAlignment="Center"
                               Margin="16,0,8,0" />
                    <TextBox x:Name="CountFieldTextBox"
                             Width="160"
                             VerticalAlignment="Center" />

                    <TextBlock x:Name="CountConstantLabel"
                               Text="Count:"
                               VerticalAlignment="Center"
                               Margin="16,0,8,0" />
                    <TextBox x:Name="CountConstantTextBox"
                             Width="80"
                             VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Child Collection:"
                           VerticalAlignment="Center"
                           Margin="0,4,8,4" />
                <ComboBox Grid.Row="2" Grid.Column="1"
                          x:Name="ChildCollectionComboBox"
                          IsEditable="True"
                          Width="160"
                          Margin="0,4,0,4" />
            </Grid>
        </GroupBox>

        <!-- =========================================================================== -->
        <!-- Bottom:  Save / Close                                                       -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click" />
            <Button x:Name="CloseButton"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>