<Window x:Class="Inference.Dialogs.OpcodeEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Opcode Editor"
        Width="1100"
        Height="320"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- =========================================================================== -->
        <!-- Top:  Patch level + opcode selectors                                        -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="0"
            Orientation="Horizontal"
            Margin="0,0,0,8">
            <TextBlock Text="Patch:"
               VerticalAlignment="Center"
               Margin="0,0,8,0" />
            <ComboBox x:Name="PatchLevelComboBox"
              Width="240"
              Margin="0,0,16,0"
              SelectionChanged="PatchLevelComboBox_SelectionChanged"
             />

            <TextBlock Text="Opcode:"
               VerticalAlignment="Center"
               Margin="0,0,8,0" 
             />
            <ComboBox x:Name="OpcodeComboBox"
              Width="280"
              IsEditable="True"
              Margin="0,0,16,0"
              SelectionChanged="OpcodeComboBox_SelectionChanged"
             />
            <TextBlock Text="Version:"
               VerticalAlignment="Center"
               Margin="0,0,8,0" 
             />
            <ComboBox x:Name="VersionComboBox"
                  Width="80"
                  Margin="0,0,8,0"
                  SelectionChanged="VersionComboBox_SelectionChanged"
                 />
            <Button x:Name="ClearButton"
                Content="Clear"
                Width="80"
                Margin="0,0,8,0"
                Click="ClearButton_Click" />

            <Button x:Name="DeleteOpcodeButton"
                Content="Delete Opcode"
                Width="110"/>
        </StackPanel>

        <!-- =========================================================================== -->
        <!-- Row 1:  PatchOpcode editable form                                           -->
        <!-- =========================================================================== -->
        <GroupBox Grid.Row="1"
          Header="Opcode"
          Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Name:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="1"
                 x:Name="OpcodeNameTextBox"
                 Text="OP_Name" />

                <TextBlock Grid.Row="0" Grid.Column="3"
                   Text="Hex:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="4"
                 x:Name="OpcodeHexTextBox"
                 Text="0x9cfc" />

                <TextBlock Grid.Row="0" Grid.Column="6"
                   Text="Byte Length:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="7"
                 x:Name="OpcodeByteLengthTextBox"
                 Text="4096" />

                <TextBlock Grid.Row="0" Grid.Column="9"
                   Text="Version:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="10"
                 x:Name="OpcodeVersionTextBox"
                 Text="1" />

                <TextBlock Grid.Row="0" Grid.Column="12"
                   Text="Key:"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />
                <TextBox Grid.Row="0" Grid.Column="13"
                     x:Name="OpcodeKeyTextBox"
                     IsReadOnly="True"
                     Background="{x:Null}" />

                <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Gate:"
                   VerticalAlignment="Center"
                   Margin="0,8,8,0" />
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="7"
                  x:Name="GateComboBox"
                  IsEditable="True"
                  HorizontalAlignment="Left"
                  Width="360"
                  Margin="0,8,0,0" />
            </Grid>
        </GroupBox>

        <!-- =========================================================================== -->
        <!-- Bottom:  Save / Close                                                       -->
        <!-- =========================================================================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="SaveButton_Click"/>
            <Button x:Name="CloseButton"
                    Content="Close"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>