<Window x:Class="Inference.Dialogs.LaunchProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Launch Profile" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Launch" Click="Button_Launch_Click" Padding="16,4"
                    Margin="0,0,8,0" x:Name="ButtonLaunch" IsEnabled="False"/>
            <Button Content="Cancel" Click="Button_Cancel_Click" Padding="16,4"/>
        </StackPanel>
        <ListBox x:Name="ProfileList" SelectionChanged="ProfileList_SelectionChanged"/>
    </DockPanel>
</Window>
