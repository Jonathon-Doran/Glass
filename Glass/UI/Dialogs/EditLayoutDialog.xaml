<Window x:Class="Glass.EditLayoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:Glass.Core"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Edit Layout"
        Height="700" Width="700"
        MinHeight="500" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <local:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                    TrueBrush="DodgerBlue"
                                    FalseBrush="Gray"/>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Save / Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="80"
                    Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Layout Name -->
            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Left" Text="Name:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <TextBox x:Name="LayoutNameTextBox"/>
            </DockPanel>

            <!-- Machine -->
            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Left" Text="Machine:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <ComboBox x:Name="MachineComboBox" Width="200"
                          SelectionChanged="MachineComboBox_SelectionChanged"/>
            </DockPanel>

            <!-- Monitor Count -->
            <DockPanel Grid.Row="4">
                <TextBlock DockPanel.Dock="Left" Text="Number of Monitors:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <ComboBox x:Name="MonitorCountComboBox" Width="80"
                          SelectionChanged="MonitorCountChanged">
                    <ComboBoxItem Content="1"/>
                    <ComboBoxItem Content="2"/>
                    <ComboBoxItem Content="3"/>
                    <ComboBoxItem Content="4"/>
                </ComboBox>
            </DockPanel>

            <!-- Layout Strategy and UI Skin -->
            <StackPanel Grid.Row="6" Orientation="Horizontal">
                <TextBlock Text="Layout Strategy:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <ComboBox x:Name="LayoutStrategyComboBox" Width="200"
                          SelectedIndex="0"
                          SelectionChanged="LayoutStrategyChanged">
                    <ComboBoxItem Content="Fixed Window Size"
                                  ToolTip="Each character window has a fixed size."/>
                    <ComboBoxItem Content="Subset and Swap"
                                  ToolTip="Display a subset of windows and swap between them."/>
                    <ComboBoxItem Content="Summary Windows"
                                  ToolTip="Display summary windows and focus full windows as needed."/>
                </ComboBox>
                <TextBlock Text="UI Skin:" VerticalAlignment="Center"
                           Margin="24,0,8,0"/>
                <ComboBox x:Name="UISkinComboBox" Width="160"/>
            </StackPanel>

            <!-- Monitor Configuration Cards -->
            <ScrollViewer Grid.Row="8" HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="MonitorConfigItemsControl"
                  ItemsSource="{Binding Monitors}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"
                                        BorderThickness="2" Margin="4"
                                        Background="Transparent"
                                        MouseLeftButtonDown="MonitorRectangle_MouseLeftButtonDown">
                                <StackPanel Margin="8">
                                    <Grid>
                                        <Rectangle x:Name="MonitorRectangle"
                                       Width="{Binding OverlayCanvasWidth}"
                                       Height="{Binding OverlayCanvasHeight}"
                                       Stroke="Black" Fill="LightGray"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                       MouseLeftButtonDown="MonitorRectangle_MouseLeftButtonDown"
                                       Panel.ZIndex="0"/>
                                        <Canvas x:Name="OverlayCanvas"
                                    Width="{Binding OverlayCanvasWidth}"
                                    Height="{Binding OverlayCanvasHeight}"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background="Transparent"
                                    IsHitTestVisible="False"
                                    Panel.ZIndex="1"/>
                                    </Grid>
                                    <TextBlock Text="{Binding LayoutPosition}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    <ComboBox x:Name="comboBoxResolution" Width="120" Margin="0,4,0,0"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding SelectedResolution}"
                                  SelectionChanged="MonitorSettingsChanged">
                                        <ComboBoxItem Content="1920x1080"/>
                                        <ComboBoxItem Content="2560x1440"/>
                                        <ComboBoxItem Content="3840x2160"/>
                                    </ComboBox>
                                    <ComboBox x:Name="comboBoxOrientation" Width="120" Margin="0,4,0,0"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding Monitor.Orientation}"
                                  SelectionChanged="MonitorSettingsChanged">
                                        <ComboBoxItem Content="Landscape"/>
                                        <ComboBoxItem Content="Portrait"/>
                                    </ComboBox>
                                    <DockPanel Margin="0,4,0,0">
                                        <TextBlock DockPanel.Dock="Left" Text="Slot Width:"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBox x:Name="SlotWidthTextBox" Width="60"
                                     Text="{Binding SlotWidth, UpdateSourceTrigger=PropertyChanged}"
                                     TextChanged="SlotWidthChanged"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Preferred Window Size -->
            <StackPanel x:Name="WindowSizeInputs" Grid.Row="10"
                        Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="Preferred Size:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <TextBlock x:Name="PreferredSizeTextBlock" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider x:Name="PreferredWidthSlider"
                        Minimum="100" Maximum="3840" Width="200"
                        SmallChange="10" LargeChange="100"
                        IsSnapToTickEnabled="True"
                        ValueChanged="PreferredWidthSlider_ValueChanged"/>
            </StackPanel>

            <!-- Grid Size -->
            <StackPanel x:Name="GridSizeInputs" Grid.Row="12"
                        Orientation="Horizontal" Visibility="Collapsed">
                <TextBlock Text="Grid Size:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <TextBlock x:Name="GridSizeTextBlock" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="Total Slots:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="TotalSlotsTextBlock" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Slot Width (global, for selected monitor) -->
            <DockPanel Grid.Row="14">
                <TextBlock DockPanel.Dock="Left" Text="Slot Width:" VerticalAlignment="Center"
                           Width="140" Margin="0,0,8,0"/>
                <TextBlock x:Name="SlotWidthSummaryTextBlock" VerticalAlignment="Center"/>
            </DockPanel>

        </Grid>
    </DockPanel>
 </Window>