<Window x:Class="Glass.ClientUI.NewCharacterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="New Character" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Name" Margin="0,0,0,4"/>
        <TextBox x:Name="CharacterName" Margin="0,0,0,12"/>
        <TextBlock Text="Server" Margin="0,0,0,4"/>
        <TextBox x:Name="CharacterServer" IsReadOnly="True" Margin="0,0,0,12"/>
        <TextBlock Text="Class" Margin="0,0,0,4"/>
        <ComboBox x:Name="ClassComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,12"/>
        <TextBlock Text="Account ID" Margin="0,0,0,4"/>
        <TextBox x:Name="AccountIdBox" Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="Button_OK_Click" Padding="16,4" Margin="0,0,8,0"
                    x:Name="ButtonOK" IsEnabled="False"/>
            <Button Content="Cancel" Click="Button_Cancel_Click" Padding="16,4"/>
        </StackPanel>
    </StackPanel>
</Window>
