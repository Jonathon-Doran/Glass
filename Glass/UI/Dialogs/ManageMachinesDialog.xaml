<Window x:Class="Glass.ManageMachinesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Manage Machines"
        Height="500" Width="600"
        MinHeight="350" MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: machine list -->
        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="MachineListView"
                          SelectionChanged="MachineListView_SelectionChanged"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                            <Setter Property="Padding" Value="4,2,4,2"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Name="NewMachineButton" Content="New" Width="70" Margin="0,0,8,0" IsEnabled="False" Click="NewMachine_Click"/>
                <Button x:Name="DeleteMachineButton" Content="Delete" Width="70"
                        IsEnabled="False" Click="DeleteMachine_Click"/>
            </StackPanel>
        </Grid>

        <!-- Right: machine editor -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Name -->
            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Left" Text="Name:" VerticalAlignment="Center" Width="70" Margin="0,0,8,0"/>
                <TextBox x:Name="MachineNameTextBox"
                     TextChanged="MachineNameTextBox_TextChanged"/>
            </DockPanel>

            <!-- Device list header -->
            <TextBlock Grid.Row="2" Text="Devices:" FontWeight="SemiBold"/>

            <!-- Device list -->
            <Border Grid.Row="4" BorderBrush="Gray" BorderThickness="1">
                <ListView x:Name="DeviceListView"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Type" Width="120"
                                            DisplayMemberBinding="{Binding KeyboardType}"/>
                            <GridViewColumn Header="Instances" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding InstanceCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="50"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Device buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal">
                <Button x:Name="AddDeviceButton" Content="Add Device" Width="90" Margin="0,0,8,0" Click="AddDevice_Click" IsEnabled="False"/>
                <Button x:Name="RemoveDeviceButton" Content="Remove" Width="70"
                        IsEnabled="False" Click="RemoveDevice_Click"/>
            </StackPanel>
        </Grid>
        
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" 
            Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="70" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="70" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>