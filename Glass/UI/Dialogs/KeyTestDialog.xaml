<Window x:Class="Glass.KeyTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Glass.Controls"
        Title="Key Test"
        Width="200"
        Height="150"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
            controls:KeyboardLayoutControl.KeyPressed="Key_Pressed"
            controls:KeyboardLayoutControl.KeyReleased="Key_Released">
            <controls:KeyDisplayControl KeyName="G1" Margin="1"/>
            <controls:KeyDisplayControl KeyName="G2" KeyType="Toggle" Margin="1"/>
        </StackPanel>
    </Grid>
</Window>
