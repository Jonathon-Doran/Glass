<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Glass.Controls">

    <Style TargetType="{x:Type controls:KeyDisplayControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyDisplayControl}">
                    <Border x:Name="PART_Border"
                        Background="#1A2A2A"
                        BorderBrush="#2AFFD7"
                        BorderThickness="1"
                        CornerRadius="3"
                        Width="70"
                        Height="24">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="InteractionStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="Selected">
                                    <Storyboard>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Border"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FFD700"
                                        Duration="0:0:0.1"/>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Text"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FFD700"
                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Border"
                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                        To="#FF4500"
                                        Duration="0:0:0.05"/>
                                        <ColorAnimation
                                        Storyboard.TargetName="PART_Text"
                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                        To="#FF4500"
                                        Duration="0:0:0.05"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <TextBlock x:Name="PART_Text"
                               Text="{TemplateBinding KeyName}"
                               Foreground="#2AFFD7"
                               FontFamily="Segoe UI"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowLabel" Value="True">
                            <Setter TargetName="PART_Text" Property="Text" Value="{Binding Label, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>